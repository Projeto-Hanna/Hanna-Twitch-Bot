{
  "name": "hanna-twitch-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Hanna Twitch Bot",
  "main": "./dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "dev": "nodemon -e ts,js --exec ts-node src/index.ts",
    "start": "node --no-warnings ./dist/index.js",
    "pm2": "pm2 start npm -- run start",
    "lint": "eslint src --ext .ts",
    "test": "jest --verbose ./tests"
  },
  "author": "Projeto Hanna",
  "license": "ISC",
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@twurple/auth": "^8.0",
    "@twurple/easy-bot": "^8.0",
    "dotenv": "^17.3",
    "globals": "^17.4.0",
    "typescript": "^6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0",
    "@typescript-eslint/eslint-plugin": "^8.17",
    "@typescript-eslint/parser": "^8.17",
    "eslint": "^10.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1",
    "eslint-import-resolver-typescript": "^4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2",
    "jest": "^30.3",
    "nodemon": "^3.1",
    "prettier": "^3.4",
    "ts-jest": "^29.2",
    "ts-node": "^10.9.2"
  }
}
